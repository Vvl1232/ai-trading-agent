# Trading AI Agent - Environment Configuration
# Copy this file to .env and fill in your actual API keys

# SEC API Credentials
# Get from: https://sec-api.com/
SEC_API_KEY=your_sec_api_key_here

# Apify API Credentials
# Get from: https://apify.com/
APIFY_API_KEY=your_apify_api_key_here

# OpenRouter API Credentials
# Get from: https://openrouter.ai/
# Used for sentiment analysis with Mistral-7B
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Output directory for reports and charts
OUTPUT_DIR=outputs

# Optional: Number of tweets per ticker
TWEETS_PER_TICKER=100

# Optional: SEC query range
SEC_QUERY_RANGE=NOW-7DAYS
